{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["@figma/plugin-typings", "node"]
  },
  "include": ["packages/**/*.ts", "plugins/**/*.ts", "tests/**/*.ts", "scripts/**/*.mjs"]
}
